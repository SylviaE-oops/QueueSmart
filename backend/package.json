{
  "name": "queuesmart-backend",
  "version": "2.0.0",
  "description": "QueueSmart full-stack backend",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "migrate": "node migrate.js",
    "start": "node server.js",
    "dev": "node server.js",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "mysql2": "^3.11.3",
    "supertest": "^7.2.2"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "server.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
